# Configure these in local or Streamlit deployment secrets; never commit a key.
OPENAI_API_KEY=

# Require live OpenAI/Chroma retrieval for study deployment; no offline fallback.
AGENTIC_REQUIRE_LIVE_RAG=true

# GitHub private data repository (session logs)
# Generate a Personal Access Token with 'repo' scope at: https://github.com/settings/tokens
GITHUB_DATA_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_DATA_REPO=owner/hiring-study-data-private

# Qualtrics / Prolific return URL (injected by Qualtrics as a URL parameter)
# The app reads ?return=<URL>&pid=<PID>&PROLIFIC_PID=<PID> automatically from the query string.
# No env var needed — set the return URL in your Qualtrics survey flow.
